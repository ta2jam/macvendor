{
	email admin@macvendor.io
}

www.macvendor.io {
	redir https://macvendor.io{uri} permanent
}

macvendor.io {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		-Server
	}

	reverse_proxy 127.0.0.1:3000 {
		# The firewall admits web traffic only from Cloudflare networks, so this
		# header is trusted as the end-user address for application rate limiting.
		header_up X-Real-IP {http.request.header.CF-Connecting-IP}
	}

	log {
		output file /var/log/caddy/macvendor-access.log {
			roll_size 10MiB
			roll_keep 5
			roll_keep_for 168h
		}
		format json
	}
}
