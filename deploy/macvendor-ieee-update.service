[Unit]
Description=Update macvendor.io IEEE source snapshot
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/macvendor-ieee-update
User=root
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=-/srv/sites/macvendor
TimeoutStartSec=45m
