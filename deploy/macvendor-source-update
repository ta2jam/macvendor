#!/bin/sh
set -eu

ROOT=/srv/sites/macvendor
WORK="$ROOT/source-work/$(date -u +%Y%m%dT%H%M%SZ)"
mkdir -p "$WORK/ieee" "$WORK/enrichments"
chmod 0700 "$ROOT/source-work" "$WORK" "$WORK/ieee" "$WORK/enrichments"

systemctl start macvendor-backup.service

docker run --rm \
  --network macvendor_default \
  --env-file "$ROOT/.env" \
  --env-file "$ROOT/release.env" \
  -e OPERATOR_ACTOR_ID=operator:scheduled-source-update \
  -v "$ROOT/source-work:/work" \
  -v "$ROOT/secrets/ingest-private.pem:/run/secrets/ingest-private.pem:ro" \
  --entrypoint sh macvendor-tooling:current -lc "
    encoded=\"\$(node -e \"process.stdout.write(encodeURIComponent(process.env.POSTGRES_PASSWORD))\")\"
    export DATABASE_URL=\"postgresql://macvendor:\${encoded}@database:5432/macvendor\"
    npm run source:update:ieee -- --output /work/$(basename "$WORK")/ieee --private-key /run/secrets/ingest-private.pem
    npm run source:update:enrichments -- --ieee-dir /work/$(basename "$WORK")/ieee --output /work/$(basename "$WORK")/enrichments --private-key /run/secrets/ingest-private.pem
  "

systemctl start macvendor-backup.service
find "$ROOT/source-work" -mindepth 1 -maxdepth 1 -type d -mtime +14 -exec rm -rf -- {} +
