{
  "name": "macvendor",
  "version": "0.1.2",
  "type": "module",
  "private": false,
  "description": "Source-aware MAC address block assignment lookup service.",
  "license": "MIT",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start-standalone.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "browser:install": "playwright install --with-deps chromium firefox webkit",
    "test:browser": "playwright test",
    "benchmark:lookup": "tsx scripts/benchmark-lookup.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrations:verify": "tsx scripts/verify-migrations.ts",
    "db:seed": "tsx scripts/seed.ts",
    "source:import": "tsx scripts/import-source.ts",
    "source:validate": "tsx scripts/validate-source.ts",
    "source:fetch": "tsx scripts/fetch-source.ts",
    "source:prepare:ieee": "tsx scripts/prepare-ieee-source.ts",
    "source:update:ieee": "tsx scripts/update-ieee-source.ts",
    "source:health": "tsx scripts/source-health.ts",
    "source:governance": "tsx scripts/source-governance.ts",
    "resolution:build": "tsx scripts/build-resolution.ts",
    "resolution:activate": "tsx scripts/activate-resolution.ts",
    "resolution:rollback": "tsx scripts/rollback-resolution.ts",
    "suppression:create": "tsx scripts/publication-suppression.ts create",
    "suppression:revoke": "tsx scripts/publication-suppression.ts revoke",
    "suppression:list": "tsx scripts/publication-suppression.ts list",
    "suppression:expire": "tsx scripts/publication-suppression.ts expire",
    "staging:smoke": "sh scripts/staging-smoke.sh",
    "recovery:backup": "tsx scripts/backup-database.ts",
    "recovery:restore": "tsx scripts/restore-database.ts",
    "recovery:rebuild": "tsx scripts/rebuild-database.ts",
    "recovery:smoke": "tsx scripts/recovery-smoke.ts",
    "db:test:prepare": "tsx scripts/prepare-test-db.ts",
    "test:integration": "npm run db:test:prepare && vitest run tests/integration",
    "verify": "npm run db:migrations:verify && npm run lint && npm run typecheck && npm run test && npm run test:integration && npm run build"
  },
  "dependencies": {
    "csv-parse": "^7.0.1",
    "dotenv": "17.2.3",
    "next": "16.2.10",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "24.10.1",
    "@types/pg": "8.15.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "postcss": "8.5.16"
  }
}
